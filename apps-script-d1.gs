// Verifica feriados nacionais brasileiros
function isFeriado(data) {
  const d = data.getDate();
  const m = data.getMonth() + 1; // 1-12
  const y = data.getFullYear();

  // Feriados fixos nacionais
  const fixos = [
    [1,  1],  // Ano Novo
    [21, 4],  // Tiradentes
    [1,  5],  // Dia do Trabalho
    [7,  9],  // Independencia
    [12, 10], // N. Sra. Aparecida
    [2,  11], // Finados
    [15, 11], // Proclamacao da Republica
    [20, 11], // Consciencia Negra
    [25, 12], // Natal
  ];
  for (var i = 0; i < fixos.length; i++) {
    if (d === fixos[i][0] && m === fixos[i][1]) return true;
  }

  // Pascoa (algoritmo de Butcher)
  var a = y % 19;
  var b = Math.floor(y / 100);
  var c = y % 100;
  var dd = Math.floor(b / 4);
  var e = b % 4;
  var f = Math.floor((b + 8) / 25);
  var g = Math.floor((b - f + 1) / 3);
  var h = (19 * a + b - dd - g + 15) % 30;
  var i2 = Math.floor(c / 4);
  var k = c % 4;
  var l = (32 + 2 * e + 2 * i2 - h - k) % 7;
  var mm = Math.floor((a + 11 * h + 22 * l) / 451);
  var mesPascoa = Math.floor((h + l - 7 * mm + 114) / 31);
  var diaPascoa = ((h + l - 7 * mm + 114) % 31) + 1;
  var pascoa = new Date(y, mesPascoa - 1, diaPascoa);

  // Sexta-feira Santa (2 dias antes da Pascoa)
  var sextaSanta = new Date(pascoa); sextaSanta.setDate(pascoa.getDate() - 2);
  // Carnaval Segunda (48 dias antes da Pascoa)
  var carnavalSeg = new Date(pascoa); carnavalSeg.setDate(pascoa.getDate() - 48);
  // Carnaval Terca (47 dias antes)
  var carnavalTer = new Date(pascoa); carnavalTer.setDate(pascoa.getDate() - 47);
  // Corpus Christi (60 dias apos a Pascoa)
  var corpus = new Date(pascoa); corpus.setDate(pascoa.getDate() + 60);

  var moveis = [sextaSanta, carnavalSeg, carnavalTer, corpus];
  for (var j = 0; j < moveis.length; j++) {
    if (d === moveis[j].getDate() && m === moveis[j].getMonth() + 1) return true;
  }

  return false;
}


// ─── ADMIN: endpoint GET para painel ────────────────────────────
function doGet(e) {
  const action = (e && e.parameter && e.parameter.action) || '';

  if (action === 'resumo') {
    try { enviarResumoSemanal(); return jsonResp({ok:true}); }
    catch(err) { return jsonResp({erro: err.message}); }
  }

  try {
    const ss    = SpreadsheetApp.openById(SHEET_ID);
    const sheet = ss.getSheetByName('D1FITNESS · Inteligência de Produto');
    const lastRow = sheet ? sheet.getLastRow() : -1;
    if (!sheet) return jsonResp({debug:'aba nao encontrada', sheetId:SHEET_ID, abas: ss.getSheets().map(s=>s.getName())});
    if (lastRow < 2) return jsonResp({debug:'sem dados', lastRow:lastRow, sheetId:SHEET_ID, abas: ss.getSheets().map(s=>s.getName())});
    const raw  = sheet.getDataRange().getValues();
    const hdrs = raw[0];
    const rows = raw.slice(1).map(r => {
      const o = {}; hdrs.forEach((h,i) => { o[h] = r[i]; }); return o;
    });
    // Also get ranking from Gamificacao sheet
    const ranking = [];
    var gamDebug = '';
    try {
      const allSheets = ss.getSheets().map(function(s){ return s.getName(); });
      gamDebug = allSheets.join('|');
      const gs = ss.getSheetByName('Gamificacao') || ss.getSheetByName('Gamificação');
      if (gs && gs.getLastRow() > 1) {
        const gr = gs.getDataRange().getValues().slice(1);
        gr.forEach(function(r) {
          if (r[1]) ranking.push({pos:r[0], nome:r[1], pontos:r[2]||0, envios:r[3]||0, streak:r[4]||0, melhorStreak:r[5]||0, ultimoEnvio:r[6]||'-'});
        });
      }
    } catch(e) { gamDebug = 'erro:' + e.message; }
    return jsonResp({dados: rows, total: rows.length, ranking: ranking, _sheets: gamDebug});
  } catch(err) { return jsonResp({erro: err.message, sheetId:SHEET_ID}); }
}

function jsonResp(data) {
  return ContentService
    .createTextOutput(JSON.stringify(data))
    .setMimeType(ContentService.MimeType.JSON);
}

// ─── RESUMO SEMANAL ─────────────────────────────────────────────
function enviarResumoSemanal() {
  const agora      = new Date();
  const semanaAtras = new Date(agora.getTime() - 7*24*60*60*1000);
  const ss          = SpreadsheetApp.openById(SHEET_ID);
  const sheet       = ss.getSheetByName('D1FITNESS · Inteligência de Produto');
  if (!sheet || sheet.getLastRow() < 2) return;

  const raw    = sheet.getDataRange().getValues();
  const linhas = raw.slice(1).filter(r => {
    const ts = r[5] ? new Date(r[5]) : null;
    return ts && ts >= semanaAtras;
  });
  if (linhas.length === 0) return;

  // Contagem de produtos das linhas da semana
  const produtos = {};
  let totalReg = 0;
  linhas.forEach(r => {
    const det = String(r[4] || '');
    det.split('\n').forEach(item => {
      const mP = item.match(/produto[:\s]+([^|\n]+)/i);
      const mQ = item.match(/qtd[:\s]+(\d+)/i);
      if (mP) {
        const prod = mP[1].trim();
        const qtd  = mQ ? parseInt(mQ[1]) : 1;
        produtos[prod] = (produtos[prod] || 0) + qtd;
        totalReg += qtd;
      }
    });
  });

  const top = Object.entries(produtos).sort((a,b)=>b[1]-a[1]).slice(0,10);
  const vendsSet = [...new Set(linhas.map(r=>r[2]).filter(Boolean))];

  const html = emailHtmlResumoSemanal(top, vendsSet, linhas.length, totalReg, semanaAtras, agora);
  GmailApp.sendEmail(
    SEU_EMAIL,
    'D1FITNESS · Resumo Semanal de Inteligência de Produto',
    'Resumo da semana D1FITNESS.',
    { name: 'D1FITNESS', htmlBody: html }
  );
}

