function enviarLinksDiarios() {
  const agora = new Date();
  const dia   = agora.getDay();
  const hora  = agora.getHours();
  const min   = agora.getMinutes();
  if (dia === 0 || dia === 6) return;
  if (isFeriado(agora)) return;
  if (hora < 17 || hora >= 18) return;

  // Apenas para quem ja preencheu ao menos uma vez
  const jaPreencheram = getVendedoresQueJaPreencheram();
  const ranking = getRanking();

  VENDEDORES.forEach(v => {
    if (!jaPreencheram.has(v.nome)) return; // pula quem nunca preencheu
    const link = BASE_URL + '?vendedor=' + encodeURIComponent(v.nome);
    GmailApp.sendEmail(v.email,
      'D1FITNESS - Registre os insights de hoje',
      'Ola ' + v.nome + '! Acesse: ' + link,
      { name: 'D1FITNESS', htmlBody: emailHtmlDiario(v.nome, link, ranking) }
    );
  });
}

// Envia pagina inicial para quem NUNCA preencheu — dispara as 15h55
function enviarPaginaInicial() {
  const agora = new Date();
  const dia   = agora.getDay();
  const hora  = agora.getHours();
  const min   = agora.getMinutes();
  if (dia === 0 || dia === 6) return;
