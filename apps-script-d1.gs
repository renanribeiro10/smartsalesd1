// Normaliza o nome do vendedor para corresponder ao cadastro (case-insensitive, substring match)
function normalizarNome(nome) {
  if (!nome) return nome;
  const nomeLower = nome.trim().toLowerCase();
  // Primeiro tenta match exato (case-insensitive)
  for (var i = 0; i < VENDEDORES.length; i++) {
    if (VENDEDORES[i].nome.toLowerCase() === nomeLower) return VENDEDORES[i].nome;
  }
  // Depois tenta match parcial (nome digitado está contido no cadastro ou vice-versa)
  for (var j = 0; j < VENDEDORES.length; j++) {
    const cad = VENDEDORES[j].nome.toLowerCase();
    if (cad.indexOf(nomeLower) !== -1 || nomeLower.indexOf(cad) !== -1) {
      return VENDEDORES[j].nome;
    }
  }
  // Retorna o nome original capitalizado se não encontrar
  return nome.trim().charAt(0).toUpperCase() + nome.trim().slice(1);
}
