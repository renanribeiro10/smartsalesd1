// Retorna Set com nomes de quem ja preencheu ao menos uma vez
function getVendedoresQueJaPreencheram() {
  try {
    const ss     = SpreadsheetApp.openById(SHEET_ID);
    const sheet  = ss.getSheetByName('D1FITNESS · Inteligência de Produto');
    if (!sheet || sheet.getLastRow() < 2) return new Set();
    const dados  = sheet.getRange(2, 3, sheet.getLastRow()-1, 1).getValues();
    return new Set(dados.map(r => r[0]).filter(Boolean));
  } catch(e) { return new Set(); }
}

function lembreteNaoPreencheram() {
  const agora = new Date();
  const dia   = agora.getDay();
  const hora  = agora.getHours();
  const min   = agora.getMinutes();
  if (dia === 0 || dia === 6) return;
  if (isFeriado(agora)) return;
  // Janela: 17h45 - 17h58 (garante envio antes das 18h)
  if (hora < 17 || (hora === 17 && min < 45) || (hora === 17 && min > 58)) return;
  const hoje   = Utilities.formatDate(agora,'America/Sao_Paulo','dd/MM/yyyy');
  const ss     = SpreadsheetApp.openById(SHEET_ID);
  const rSheet = ss.getSheetByName('D1FITNESS · Inteligência de Produto');
  if (!rSheet) return;
  const dados    = rSheet.getDataRange().getValues();
  const enviaram = new Set();
  dados.slice(1).forEach(row => { if (row[0] === hoje) enviaram.add(row[2]); });
  VENDEDORES.forEach(v => {
    if (!enviaram.has(v.nome)) {
      const link = BASE_URL + '?vendedor=' + encodeURIComponent(v.nome);
      GmailApp.sendEmail(v.email,
        'D1FITNESS - Voce ainda nao registrou hoje',
        'Ola ' + v.nome + '! Ainda da tempo: ' + link,
        { name: 'D1FITNESS', htmlBody: emailHtmlLembrete(v.nome, link) }
      );
    }
  });
}

