function doPost(e) {
  try {
    const data = JSON.parse(e.postData.contents);
    if (data.vendedor) data.vendedor = normalizarNome(data.vendedor);
    salvarNaPlanilha(data);
    atualizarGamificacao(data);
    enviarEmails(data);
    return ok();
  } catch(err) {
    return erro(err.toString());
  }
}

function salvarNaPlanilha(data) {
  const ss  = SpreadsheetApp.openById(SHEET_ID);
  let sheet = ss.getSheetByName('D1FITNESS · Inteligência de Produto');
  if (!sheet) {
    sheet = ss.insertSheet('Registros');
    sheet.appendRow(['Data','Hora','Vendedor','Total Registros','Registros Detalhados','Timestamp']);
    sheet.getRange(1,1,1,6).setFontWeight('bold').setBackground('#FF5C00').setFontColor('white');
  }
  const now = new Date();
  sheet.appendRow([
    data.data  || Utilities.formatDate(now,'America/Sao_Paulo','dd/MM/yyyy'),
    data.hora  || Utilities.formatDate(now,'America/Sao_Paulo','HH:mm'),
    data.vendedor        || '-',
    data.total_registros || 0,
    data.registros       || '-',
    now.toISOString()
  ]);
}

function atualizarGamificacao(data) {
  const ss   = SpreadsheetApp.openById(SHEET_ID);
  let gSheet = ss.getSheetByName('Gamificacao');
  if (!gSheet) {
    gSheet = ss.insertSheet('Gamificacao');
    gSheet.appendRow(['Pos','Vendedor','Pontos','Envios','Streak','Melhor Streak','Ultimo Envio']);
    gSheet.getRange(1,1,1,7).setFontWeight('bold').setBackground('#FF5C00').setFontColor('white');
    VENDEDORES.forEach((v,i) => gSheet.appendRow([i+1, v.nome, 0, 0, 0, 0, '-']));
  }
  const vendedor    = data.vendedor;
  const hoje        = Utilities.formatDate(new Date(),'America/Sao_Paulo','dd/MM/yyyy');
  const nRegistros  = parseInt(data.total_registros) || 0;
  const hora        = new Date().getHours();
  const pontosBase  = hora < 18 ? 10 : 5;
  const isSemDemanda = (data.tipo === 'sem_demanda') || (String(data.registros||'').indexOf('Sem demandas hoje') !== -1);
  const totalPontos = isSemDemanda ? 1 : pontosBase + (nRegistros * 2);
  const dados       = gSheet.getDataRange().getValues();
  let linhaIdx      = -1;
  for (let i = 1; i < dados.length; i++) {
    if (dados[i][1] && dados[i][1].toString().toLowerCase() === vendedor.toLowerCase()) { linhaIdx = i + 1; break; }
  }
  if (linhaIdx === -1) {
    gSheet.appendRow([dados.length, vendedor, totalPontos, 1, 1, 1, hoje]);
  } else {
    const pontuacaoAtual = dados[linhaIdx-1][2] || 0;
    const enviosAtuais   = dados[linhaIdx-1][3] || 0;
    const streakAtual    = dados[linhaIdx-1][4] || 0;
    const melhorStreak   = dados[linhaIdx-1][5] || 0;
    const ultimoEnvio    = dados[linhaIdx-1][6] || '';
    let novoStreak = 1;
    if (ultimoEnvio !== '-' && ultimoEnvio !== '') {
      const ontem = new Date(); ontem.setDate(ontem.getDate() - 1);
      const ontemDia = ontem.getDay();
      let diaAnteriorUtil = Utilities.formatDate(ontem,'America/Sao_Paulo','dd/MM/yyyy');
      if (ontemDia === 0) {
        const sexta = new Date(); sexta.setDate(sexta.getDate() - 3);
        diaAnteriorUtil = Utilities.formatDate(sexta,'America/Sao_Paulo','dd/MM/yyyy');
      }
      novoStreak = (ultimoEnvio === diaAnteriorUtil) ? streakAtual + 1 : 1;
    }
    const bonusStreak = (novoStreak % 5 === 0) ? 15 : 0;
    gSheet.getRange(linhaIdx, 3).setValue(pontuacaoAtual + totalPontos + bonusStreak);
    gSheet.getRange(linhaIdx, 4).setValue(enviosAtuais + 1);
    gSheet.getRange(linhaIdx, 5).setValue(novoStreak);
    gSheet.getRange(linhaIdx, 6).setValue(Math.max(melhorStreak, novoStreak));
    gSheet.getRange(linhaIdx, 7).setValue(hoje);
  }
  atualizarRanking(gSheet);
}

function atualizarRanking(gSheet) {
  const range = gSheet.getRange(2, 1, gSheet.getLastRow()-1, 7);
  const dados = range.getValues();
  dados.sort((a, b) => b[2] - a[2]);
  dados.forEach((row, i) => row[0] = i + 1);
  range.setValues(dados);
  gSheet.getRange(2,1,1,7).setBackground('#FFD700').setFontColor('#333');
  if (dados.length > 1) gSheet.getRange(3,1,1,7).setBackground('#C0C0C0').setFontColor('#333');
  if (dados.length > 2) gSheet.getRange(4,1,1,7).setBackground('#CD7F32').setFontColor('#333');
  if (dados.length > 3) gSheet.getRange(5,1,dados.length-3,7).setBackground('#F9F9F9').setFontColor('#333');
}

