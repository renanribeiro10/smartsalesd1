function getRanking() {
  try {
    const ss = SpreadsheetApp.openById(SHEET_ID);
    const gs = ss.getSheetByName('Gamificacao');
    if (!gs) return [];
    return gs.getDataRange().getValues().slice(1).map(r => ({ pos:r[0], nome:r[1], pontos:r[2], streak:r[4] }));
  } catch(e) { return []; }
}

